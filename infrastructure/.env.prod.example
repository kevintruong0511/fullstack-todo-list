# Copy to .env.prod and fill with real values. NEVER commit .env.prod.
#
# Used by docker-compose.prod.yml:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# PostgreSQL credentials (also injected into backend as DB_*)
POSTGRES_USER=todo_user
POSTGRES_PASSWORD=replace-with-strong-random-password
POSTGRES_DB=todo_db

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# Host port the frontend (Nginx) binds to. Use 80 on the VPS.
# Override to 8080 when testing locally if port 80 is busy.
HTTP_PORT=80
